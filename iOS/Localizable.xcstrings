    "Create a scene to set multiple blinds with a single tap — \"Morning\", \"Shade\", \"Night\".": {
      "extractionState": "manual",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vytvoř scénu, která jedním tapnutím nastaví víc žaluzií — „Ráno“, „Stínění“, „Noc“."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erstelle eine Szene, die mit einem Tipp mehrere Jalousien einstellt – „Morgen“, „Schatten“, „Nacht“."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Crea una escena que ajuste varias persianas con un solo toque: «Mañana», «Sombra», «Noche»."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Créez une scène qui règle plusieurs stores d'un seul geste — « Matin », « Ombre », « Nuit »."
          }
        }
      }
    },
    "Credentials arrive via iCloud Keychain, usually within seconds.": {
      "extractionState": "manual",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Přihlášení dorazí přes iCloud Klíčenku, obvykle do několika vteřin."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Anmeldedaten kommen über den iCloud-Schlüsselbund an, meist innerhalb von Sekunden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las credenciales llegan a través del llavero de iCloud, normalmente en unos segundos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les identifiants arrivent via le trousseau iCloud, généralement en quelques secondes."
          }
        }
      }
    },
