    "After signing in, credentials are saved to iCloud Keychain and synced to your Apple Watch (even without an iPhone nearby).": {
      "extractionState": "manual",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Po přihlášení se přihlašovací údaje uloží do iCloud Klíčenky a přenesou se na tvé Apple Watch (i bez iPhonu)."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nach der Anmeldung werden die Zugangsdaten im iCloud-Schlüsselbund gespeichert und auf deine Apple Watch synchronisiert (auch ohne iPhone in der Nähe)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tras iniciar sesión, las credenciales se guardan en el llavero de iCloud y se sincronizan con tu Apple Watch (incluso sin tener un iPhone cerca)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Après la connexion, vos identifiants sont enregistrés dans le trousseau iCloud et synchronisés sur votre Apple Watch (même sans iPhone à proximité)."
          }
        }
      }
    },
