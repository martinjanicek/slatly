    "Pick from 7 colors in the top-right of the detail view — saved per blind.": {
      "extractionState": "manual",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "V detailu vpravo nahoře vybereš jednu ze 7 barev — uloží se per žaluzii."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle oben rechts in der Detailansicht eine von 7 Farben – wird pro Jalousie gespeichert."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige uno de los 7 colores en la esquina superior derecha del detalle: se guarda por persiana."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez l'une des 7 couleurs en haut à droite du détail — enregistrée par store."
          }
        }
      }
    },
