    "Rotate the crown to tilt the slats (open or block direct light).": {
      "extractionState": "manual",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Točením korunky naklápíš lamely (otevřeš/zavřeš proud světla)."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Drehe die Krone, um die Lamellen zu neigen (Licht durchlassen oder blockieren)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Gira la corona para inclinar las lamas (deja pasar o bloquea la luz directa)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
